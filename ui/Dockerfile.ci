# Use official Playwright image - includes Chromium, Firefox, WebKit + all system deps + Node.js
FROM mcr.microsoft.com/playwright:v1.58.1-jammy

WORKDIR /app

# Set browser cache path (browsers already present from official image)
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# Copy package files and install dependencies
COPY package.json package-lock.json ./
RUN npm ci

# Copy source code
COPY . .

# Set environment variables for headless testing
ENV NODE_ENV=ci

CMD ["bash", "./ci.sh"]